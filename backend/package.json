{
  "name": "clario-backend",
  "version": "1.0.0",
  "description": "Express backend for Clario",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev": "concurrently -n Web,Worker -c blue,green \"npm run dev:server\" \"npm run dev:worker\"",
    "build": "npx prisma generate && tsc",
    "start": "node dist/index.js",
    "start:web": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.110.0",
    "@types/multer": "^2.1.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.3",
    "langsmith": "^0.7.14",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/pdfkit": "^0.17.6",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
